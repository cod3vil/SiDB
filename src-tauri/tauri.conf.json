{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SiDB",
  "mainBinaryName": "SiDB",
  "version": "1.2.2",
  "identifier": "app.sidb.client",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SiDB",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; worker-src 'self' blob:",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "wix": {},
      "nsis": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEMTBGNTJGOTE2OUVFREUKUldUZTdtbVJML1VRN1liQUhYbThZVTZhWnp0czBxUDFMemVndEpXTVJuVHZCMS9FNVRDbGFVbTAK",
      "endpoints": [
        "https://update.cyberran.com/api/update/sidb/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
